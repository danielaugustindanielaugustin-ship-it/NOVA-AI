<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - NOVA AI</title>
    <link rel="stylesheet" href="css/dashboard.css">
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo"><span>NOVA AI</span></div>
            <ul class="nav-menu">
                <li><a href="index.html">Home</a></li>
                <li><a href="chatbot.html">AI Chatbot</a></li>
                <li><a href="image-generator.html">Image Generator</a></li>
                <li><a href="dashboard.html" class="active">Dashboard</a></li>
                <li><a href="profile.html">Profile</a></li>
            </ul>
        </div>
    </nav>

    <div class="dashboard-container">
        <h1>NOVA AI Dashboard</h1>
        
        <div class="dashboard-grid">
            <div class="dashboard-card">
                <h3>AI Usage</h3>
                <p class="usage-count">Total Interactions: <span id="totalInteractions">0</span></p>
            </div>
            
            <div class="dashboard-card">
                <h3>Chat History</h3>
                <div id="chatHistory" class="history-list">
                    <p>No chat history yet</p>
                </div>
            </div>
            
            <div class="dashboard-card">
                <h3>Image Generation</h3>
                <p class="usage-count">Images Created: <span id="totalImages">0</span></p>
            </div>
            
            <div class="dashboard-card">
                <h3>Recent Images</h3>
                <div id="imageGallery" class="image-gallery">
                    <p>No images generated yet</p>
                </div>
            </div>
        </div>
    </div>

    <script src="js/dashboard.js"></script>
</body>
</html>