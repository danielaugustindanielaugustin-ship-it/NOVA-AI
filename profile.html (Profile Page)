<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile - NOVA AI</title>
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo"><span>NOVA AI</span></div>
            <ul class="nav-menu">
                <li><a href="index.html">Home</a></li>
                <li><a href="chatbot.html">AI Chatbot</a></li>
                <li><a href="dashboard.html">Dashboard</a></li>
                <li><a href="profile.html" class="active">Profile</a></li>
                <li><a href="login.html">Login</a></li>
            </ul>
        </div>
    </nav>

    <div class="profile-container">
        <h1>NOVA AI Profile</h1>
        
        <div class="profile-card">
            <div class="profile-header">
                <div class="avatar">
                    <img src="assets/images/user-avatar.png" alt="User Avatar">
                </div>
                <h2 id="userName">User Name</h2>
                <p id="userEmail">user@email.com</p>
            </div>
            
            <div class="profile-section">
                <h3>Account Settings</h3>
                <form id="profileForm">
                    <div class="form-group">
                        <label for="editName">Full Name</label>
                        <input type="text" id="editName" name="editName">
                    </div>
                    <div class="form-group">
                        <label for="editEmail">Email</label>
                        <input type="email" id="editEmail" name="editEmail">
                    </div>
                    <button type="submit" class="btn btn-primary">Update Profile</button>
                </form>
            </div>
            
            <div class="profile-section">
                <h3>Security</h3>
                <button id="changePassword" class="btn btn-secondary">Change Password</button>
                <button id="logout" class="btn btn-danger">Logout</button>
            </div>
        </div>
    </div>
</body>
</html>